{
  "name": "blipod",
  "version": "0.1.0",
  "description": "B站视频转Podcast播放器",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "start": "electron .",
    "start:legacy": "electron src/legacy/main.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "typecheck": "vue-tsc --noEmit"
  },
  "keywords": [
    "bilibili",
    "podcast",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "@types/qrcode": "^1.5.6",
    "@unocss/reset": "^66.6.6",
    "@vitejs/plugin-vue": "^6.0.4",
    "electron": "^28.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "unocss": "^66.6.6",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vue-tsc": "^3.2.5"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.577.0",
    "pinia": "^3.0.4",
    "qrcode": "^1.5.4",
    "radix-vue": "^1.9.17",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  }
}
